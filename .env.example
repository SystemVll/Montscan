# FTP ingress configuration
FTP_ENABLED=true
FTP_HOST=0.0.0.0
FTP_PORT=21
FTP_USERNAME=REPLACE_ME
FTP_PASSWORD=REPLACE_ME
FTP_UPLOAD_DIR=/app/scans

# Samba server configuration (polls remote SMB share for incoming PDFs)
SAMBA_SERVER_ENABLED=false
SAMBA_SERVER_HOST=127.0.0.1
SAMBA_SERVER_PORT=445
SAMBA_SERVER_USERNAME=REPLACE_ME
SAMBA_SERVER_PASSWORD=REPLACE_ME
SAMBA_SERVER_SHARE=REPLACE_ME
SAMBA_SERVER_PATH=/scans
SAMBA_SERVER_POLL_INTERVAL_SEC=10
SAMBA_SERVER_DELETE_AFTER_READ=true
SAMBA_SERVER_WORK_DIR=/app/scans

# Optional backward-compatible aliases (deprecated)
# SAMBA_INGRESS_ENABLED=
# SAMBA_INGRESS_HOST=
# SAMBA_INGRESS_PORT=
# SAMBA_INGRESS_USERNAME=
# SAMBA_INGRESS_PASSWORD=
# SAMBA_INGRESS_SHARE=
# SAMBA_INGRESS_PATH=
# SAMBA_INGRESS_POLL_INTERVAL_SEC=
# SAMBA_INGRESS_DELETE_AFTER_READ=
# SAMBA_INGRESS_WORK_DIR=

# WebDAV provider configuration
WEBDAV_ENABLED=true
WEBDAV_URL=https://cloud.example.com/webdav
WEBDAV_USERNAME=REPLACE_ME
WEBDAV_PASSWORD=REPLACE_ME
WEBDAV_INSECURE=false
LANGUAGE=English

# Samba provider configuration (processed file destination)
SAMBA_ENABLED=true
SAMBA_HOST=127.0.0.1
SAMBA_PORT=445
SAMBA_USERNAME=REPLACE_ME
SAMBA_PASSWORD=REPLACE_ME
SAMBA_SHARE=REPLACE_ME
SAMBA_PATH=/scans


OLLAMA_MODEL=ministral-3:3b